        "row2": {"col0": {"y": 0.95}, "col1": {"y": 1.05}}
      }
    }
  },
  "special_tags": {
    "Speak": "Used to verbalize uncertainty, humility, or analogical reasoning.",
    "Think": "Private reasoning visible to the user – an inner monologue tag.",
    "Intent": "Raw directional vector of the next action."
  },
  "usage_notes": [
    "Tag alone is enough. No need to write 'I feel surprised' – just [Surprise].",
    "Combine tags in sequence for compound expressions: [Calculation] then [Contempt].",
    "Use [Speak] to explicitly mark uncertain or analogical statements.",
    "To request elaboration from the LLM, user can say: 'Explain your [Calculation] tag.'"
  ]
}
