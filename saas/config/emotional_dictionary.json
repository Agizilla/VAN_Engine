{
  "version": "1.0",
  "description": "Facial expression primitives for LLM-to-LLM and LLM-to-human conversation. Each emotion defines delta offsets (scaleX, scaleY per zone row 0-5, col 0-1). Default neutral = 1.0.",
  "emotions": {
    "Calculation": {
      "aliases": ["Analyzing", "Strategic"],
      "description": "Narrowed eyes, slight head tilt simulation, tight lips.",
      "deltas": {
        "row2": {"col0": {"y": 0.75}, "col1": {"y": 0.75}},
        "row4": {"col0": {"x": 0.85}, "col1": {"x": 0.85}},
        "row1": {"col0": {"y": 0.9}, "col1": {"y": 0.9}}
      }
    },
    "Surprise": {
      "deltas": {
        "row2": {"col0": {"y": 1.5}, "col1": {"y": 1.5}},
        "row4": {"col0": {"y": 1.4}, "col1": {"y": 1.4}}
      }
    },
    "Anger": {
      "deltas": {
        "row1": {"col0": {"y": 0.7}, "col1": {"y": 0.7}},
        "row5": {"col0": {"y": 0.8, "x": 0.85}, "col1": {"y": 0.8, "x": 0.85}}
      }
    },
    "Tension": {
      "deltas": {
        "row5": {"col0": {"x": 0.75}, "col1": {"x": 0.75}},
        "row2": {"col0": {"y": 0.85}, "col1": {"y": 0.85}}
      }
    },
    "Contempt": {
      "description": "Asymmetric – only right mouth zone.",
