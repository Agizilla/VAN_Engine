        "row5": {"col0": {"x": 1.15}, "col1": {"x": 1.15}}
      }
    },
    "SmugSatisfaction": {
      "deltas": {
        "row4": {"col1": {"y": 1.25}},
        "row0": {"col0": {"y": 1.05}, "col1": {"y": 1.05}}
      }
    },
    "Panic": {
      "deltas": {
        "row2": {"col0": {"y": 1.5}, "col1": {"y": 1.5}},
        "row4": {"col0": {"y": 1.4}, "col1": {"y": 1.4}},
        "row1": {"col0": {"y": 1.2}, "col1": {"y": 1.2}}
      }
    },
    "Triumph": {
      "deltas": {
        "row2": {"col0": {"y": 1.3}, "col1": {"y": 1.3}},
        "row4": {"col0": {"y": 1.2, "x": 1.15}, "col1": {"y": 1.2, "x": 1.15}},
        "row3": {"col0": {"y": 1.1}, "col1": {"y": 1.1}}
      }
    },
    "Stonewall": {
      "deltas": {
        "row5": {"col0": {"x": 0.9}, "col1": {"x": 0.9}},
        "row2": {"col0": {"y": 0.95}, "col1": {"y": 0.95}}
      }
    },
    "Curiosity": {
      "deltas": {
        "row1": {"col0": {"y": 1.05}, "col1": {"y": 1.05}},
        "row2": {"col0": {"y": 1.1}, "col1": {"y": 1.1}}
      }
    },
    "Doubt": {
