{
  "project_name": "Artist Voice Clone v1",
  "description": "Training configuration for voice cloning with Whisper token integration",
  
  "whisper_config": {
    "model": "base",
    "language": "en",
    "temperature": 0,
    "extract_tokens": true,
    "confidence_threshold": 0.7
  },
  
  "audio_config": {
    "sample_rate": 24000,
    "n_fft": 2048,
    "hop_length": 512,
    "n_mels": 128,
    "f_min": 40,
    "f_max": 7600,
    "duration_min": 3.0,
    "duration_max": 30.0
  },
  
  "training_config": {
    "num_epochs": 100,
    "batch_size": 4,
    "learning_rate": 0.0001,
    "weight_decay": 0.0001,
    "validation_split": 0.1,
    "early_stopping_patience": 20,
    "early_stopping_threshold": 0.99
  },
  
  "model_config": {
    "base_model_path": "./models/sovits_base_model.pth",
    "hubert_model_path": "./models/hubert_base.pt",
    "vocoder_path": "./models/vocoder_gan.pth",
    "device": "cuda",
    "use_mixed_precision": true,
    "checkpoint_interval": 10
  },
  
  "data_config": {
    "training_audio_folder": "./training_data/artist_samples",
    "output_folder": "./trained_models/artist_v1",
    "augmentation": {
      "apply": true,
      "pitch_shift": true,
      "time_stretch": false,
      "gain_variation": true
    }
  },
  
  "optimization": {
    "optimizer": "Adam",
    "scheduler": "CosineAnnealingLR",
    "warmup_epochs": 5,
    "gradient_clip": 1.0
  },
  
  "logging": {
    "log_level": "INFO",
    "save_interval": 10,
    "tensorboard": true,
    "wandb": false
  }
}
