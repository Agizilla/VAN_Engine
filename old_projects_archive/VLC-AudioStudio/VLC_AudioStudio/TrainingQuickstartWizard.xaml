<Window x:Class="VLCPlayer.TrainingQuickstartWizard"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Voice Training Quickstart" 
        Width="700" 
        Height="550"
        Background="#1C1C1C"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize">
    
    <Window.Resources>
        <SolidColorBrush x:Key="OrangeBrush" Color="#FF9500"/>
        <SolidColorBrush x:Key="TextFg" Color="#FFFFFF"/>
        <SolidColorBrush x:Key="TextDimFg" Color="#B3B3B3"/>
        <SolidColorBrush x:Key="ButtonHoverBg" Color="#404040"/>
        
        <Style x:Key="ButtonStyle" TargetType="Button">
            <Setter Property="Background" Value="{StaticResource OrangeBrush}"/>
            <Setter Property="Foreground" Value="#000000"/>
            <Setter Property="Padding" Value="16,8"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" CornerRadius="4" Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="#FFB84D"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <Grid Background="#1C1C1C">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Header -->
        <StackPanel Grid.Row="0" Background="#0F0F0F" Margin="24,20,24,20">
            <TextBlock Text="⚡ Voice Training Quick Start" Foreground="{StaticResource OrangeBrush}" FontSize="20" FontWeight="Bold" Margin="0,0,0,8"/>
            <TextBlock Name="StepTitle" Foreground="{StaticResource TextFg}" FontSize="14" FontWeight="Bold"/>
            <TextBlock Name="StepProgress" Foreground="{StaticResource TextDimFg}" FontSize="11" Margin="0,4,0,0"/>
        </StackPanel>

        <!-- Content -->
        <TextBox Grid.Row="1" Name="ContentText" Background="#323232" Foreground="{StaticResource TextFg}" 
                 Margin="24" FontSize="13" FontFamily="Segoe UI" IsReadOnly="True" 
                 TextWrapping="Wrap" VerticalScrollBarVisibility="Auto"/>

        <!-- Buttons -->
        <StackPanel Grid.Row="2" Background="#0F0F0F" Margin="24" Orientation="Horizontal" HorizontalAlignment="Right">
            <Button Name="PreviousButton" Style="{StaticResource ButtonStyle}" Background="{StaticResource ButtonHoverBg}" Foreground="{StaticResource TextFg}" Margin="0,0,12,0">← Previous</Button>
            <Button Name="NextButton" Style="{StaticResource ButtonStyle}" Margin="0,0,12,0">Next →</Button>
            <Button Name="CloseButton" Style="{StaticResource ButtonStyle}" Background="{StaticResource ButtonHoverBg}" Foreground="{StaticResource TextFg}">Close</Button>
        </StackPanel>
    </Grid>
</Window>
