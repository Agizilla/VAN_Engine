<Window x:Class="VLCPlayer.SetupWizard"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Setup Wizard" 
        Width="800" 
        Height="600"
        Background="#1C1C1C"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize">
    
    <Window.Resources>
        <SolidColorBrush x:Key="DarkBg" Color="#1C1C1C"/>
        <SolidColorBrush x:Key="ControlBg" Color="#323232"/>
        <SolidColorBrush x:Key="OrangeBrush" Color="#FF9500"/>
        <SolidColorBrush x:Key="ButtonHoverBg" Color="#404040"/>
        <SolidColorBrush x:Key="TextFg" Color="#FFFFFF"/>
        <SolidColorBrush x:Key="TextDimFg" Color="#B3B3B3"/>
        
        <Style x:Key="ButtonStyle" TargetType="Button">
            <Setter Property="Background" Value="{StaticResource OrangeBrush}"/>
            <Setter Property="Foreground" Value="#000000"/>
            <Setter Property="Padding" Value="16,8"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" CornerRadius="4" Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="#FFB84D"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <Grid Background="{StaticResource DarkBg}">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Header -->
        <StackPanel Grid.Row="0" Background="#0F0F0F" Margin="24,20,24,20">
            <TextBlock Text="🚀 Setup Wizard" Foreground="{StaticResource OrangeBrush}" FontSize="24" FontWeight="Bold" Margin="0,0,0,8"/>
            <TextBlock Name="StepTitle" Foreground="{StaticResource TextFg}" FontSize="16" FontWeight="Bold"/>
            <TextBlock Name="StepProgress" Foreground="{StaticResource TextDimFg}" FontSize="12" Margin="0,4,0,0"/>
        </StackPanel>

        <!-- Content -->
        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
            <StackPanel Name="ContentPanel" Margin="24" />
        </ScrollViewer>

        <!-- Footer with Buttons -->
        <StackPanel Grid.Row="2" Background="#0F0F0F" Margin="24" Orientation="Horizontal" HorizontalAlignment="Right">
            <Button Name="PreviousButton" Style="{StaticResource ButtonStyle}" Background="{StaticResource ButtonHoverBg}" Foreground="{StaticResource TextFg}" Margin="0,0,12,0">← Previous</Button>
            <Button Name="NextButton" Style="{StaticResource ButtonStyle}" Margin="0,0,12,0">Next →</Button>
            <Button Name="CloseButton" Style="{StaticResource ButtonStyle}" Background="{StaticResource ButtonHoverBg}" Foreground="{StaticResource TextFg}">Close</Button>
        </StackPanel>
    </Grid>
</Window>
