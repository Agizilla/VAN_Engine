<Window x:Class="VLCPlayer.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="VLC media player" 
        Width="1400" 
        Height="800"
        Background="#1C1C1C"
        WindowStartupLocation="CenterScreen">
    
    <Window.Resources>
        <!-- Define brushes for consistent theming -->
        <SolidColorBrush x:Key="DarkBg" Color="#1C1C1C"/>
        <SolidColorBrush x:Key="ControlBg" Color="#323232"/>
        <SolidColorBrush x:Key="OrangeBrush" Color="#FF9500"/>
        <SolidColorBrush x:Key="ButtonHoverBg" Color="#404040"/>
        <SolidColorBrush x:Key="TextFg" Color="#FFFFFF"/>
        <SolidColorBrush x:Key="TextDimFg" Color="#B3B3B3"/>
        <SolidColorBrush x:Key="TabBg" Color="#2A2A2A"/>
        <SolidColorBrush x:Key="TabSelectedBg" Color="#404040"/>
        
        <!-- Button Style -->
        <Style x:Key="ToolbarButtonStyle" TargetType="Button">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Foreground" Value="{StaticResource TextFg}"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding" Value="8,4"/>
            <Setter Property="Height" Value="32"/>
            <Setter Property="Width" Value="32"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" 
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="4"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="{StaticResource ButtonHoverBg}"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Small Button Style for toolbar -->
        <Style x:Key="SmallToolbarButtonStyle" TargetType="Button" BasedOn="{StaticResource ToolbarButtonStyle}">
            <Setter Property="FontSize" Value="11"/>
            <Setter Property="Width" Value="Auto"/>
            <Setter Property="Height" Value="28"/>
            <Setter Property="Padding" Value="10,4"/>
        </Style>

        <!-- Control Button Style (for playback controls) -->
        <Style x:Key="ControlButtonStyle" TargetType="Button">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Foreground" Value="{StaticResource OrangeBrush}"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" 
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="3"
                                Padding="8">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="{StaticResource ButtonHoverBg}"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Tab Control Style -->
        <Style x:Key="AudioToolsTabControlStyle" TargetType="TabControl">
            <Setter Property="Background" Value="{StaticResource DarkBg}"/>
            <Setter Property="Foreground" Value="{StaticResource TextFg}"/>
            <Setter Property="BorderThickness" Value="0"/>
        </Style>

        <Style x:Key="AudioToolsTabItemStyle" TargetType="TabItem">
            <Setter Property="Background" Value="{StaticResource TabBg}"/>
            <Setter Property="Foreground" Value="{StaticResource TextFg}"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding" Value="12,8"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="TabItem">
                        <Grid>
                            <Border Name="Border" 
                                    Background="{TemplateBinding Background}"
                                    BorderBrush="{StaticResource OrangeBrush}"
                                    BorderThickness="0,0,0,2"
                                    Margin="0,0,-4,0">
                                <ContentPresenter x:Name="ContentSite"
                                                VerticalAlignment="Center"
                                                HorizontalAlignment="Center"
                                                ContentSource="Header"
                                                Margin="8,4"/>
                            </Border>
                        </Grid>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsSelected" Value="False">
                                <Setter TargetName="Border" Property="Background" Value="{StaticResource TabBg}"/>
                                <Setter TargetName="Border" Property="BorderThickness" Value="0"/>
                                <Setter Property="Foreground" Value="{StaticResource TextDimFg}"/>
                            </Trigger>
                            <Trigger Property="IsSelected" Value="True">
                                <Setter TargetName="Border" Property="Background" Value="{StaticResource TabSelectedBg}"/>
                                <Setter TargetName="Border" Property="BorderThickness" Value="0,0,0,3"/>
                                <Setter Property="Foreground" Value="{StaticResource OrangeBrush}"/>
                            </Trigger>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Border" Property="Background" Value="{StaticResource ButtonHoverBg}"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- TextBlock Style -->
        <Style x:Key="LabelStyle" TargetType="TextBlock">
            <Setter Property="Foreground" Value="{StaticResource TextFg}"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="Margin" Value="0,8,0,4"/>
        </Style>

        <!-- Button Style for Audio Tools -->
        <Style x:Key="AudioToolsButtonStyle" TargetType="Button">
            <Setter Property="Background" Value="{StaticResource OrangeBrush}"/>
            <Setter Property="Foreground" Value="#000000"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding" Value="12,8"/>
            <Setter Property="FontSize" Value="11"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" 
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="4"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="#FFB84D"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter Property="Background" Value="#E68400"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Secondary Button Style -->
        <Style x:Key="SecondaryButtonStyle" TargetType="Button">
            <Setter Property="Background" Value="{StaticResource ButtonHoverBg}"/>
            <Setter Property="Foreground" Value="{StaticResource TextFg}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="BorderBrush" Value="{StaticResource ControlBg}"/>
            <Setter Property="Padding" Value="10,6"/>
            <Setter Property="FontSize" Value="11"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" 
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="3"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="#505050"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <Grid Background="{StaticResource DarkBg}">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Title Bar / Menu Bar -->
        <StackPanel Grid.Row="0" Background="#0F0F0F" Height="32" Orientation="Horizontal" VerticalAlignment="Center">
            <TextBlock Text="File" Foreground="{StaticResource TextFg}" VerticalAlignment="Center" Padding="12,0" FontSize="12"/>
            <TextBlock Text="Edit" Foreground="{StaticResource TextFg}" VerticalAlignment="Center" Padding="12,0" FontSize="12"/>
            <TextBlock Text="View" Foreground="{StaticResource TextFg}" VerticalAlignment="Center" Padding="12,0" FontSize="12"/>
            <TextBlock Text="Playback" Foreground="{StaticResource TextFg}" VerticalAlignment="Center" Padding="12,0" FontSize="12"/>
            <TextBlock Text="Tools" Foreground="{StaticResource TextFg}" VerticalAlignment="Center" Padding="12,0" FontSize="12"/>
            <TextBlock Text="Help" Foreground="{StaticResource TextFg}" VerticalAlignment="Center" Padding="12,0" FontSize="12"/>
        </StackPanel>

        <!-- Toolbar -->
        <StackPanel Grid.Row="1" Background="{StaticResource ControlBg}" Height="48" Orientation="Horizontal" VerticalAlignment="Center">
            <!-- File buttons -->
            <Button Style="{StaticResource ToolbarButtonStyle}" ToolTip="Open File" FontSize="16" Name="OpenFileButton" Margin="8,0,2,0">📁</Button>
            <Button Style="{StaticResource ToolbarButtonStyle}" ToolTip="Open Directory" FontSize="16" Margin="2">📂</Button>
            <Button Style="{StaticResource ToolbarButtonStyle}" ToolTip="Open Network Stream" FontSize="16" Margin="2">🌐</Button>
            <Separator Background="{StaticResource ButtonHoverBg}" Width="1" Margin="6,0"/>
            
            <!-- Help & Setup Buttons -->
            <Button Style="{StaticResource SmallToolbarButtonStyle}" ToolTip="Setup Wizard" x:Name="SetupWizardButton" Margin="2">⚙️ Setup</Button>
            <Button Style="{StaticResource SmallToolbarButtonStyle}" ToolTip="Train Song" x:Name="SongTrainingButton" Margin="2">🎵 Train Song</Button>
            <Button Style="{StaticResource SmallToolbarButtonStyle}" ToolTip="Voice Training Guide" x:Name="TrainingGuideButton" Margin="2">📖 Guide</Button>
            <Button Style="{StaticResource SmallToolbarButtonStyle}" ToolTip="Quick Train" x:Name="QuickTrainButton" Margin="2">⚡ Quick Train</Button>
            <Button Style="{StaticResource SmallToolbarButtonStyle}" ToolTip="Quick Start" x:Name="QuickstartButton" Margin="2">⚡ Quick Start</Button>
            <Separator Background="{StaticResource ButtonHoverBg}" Width="1" Margin="6,0"/>
            
            <!-- View buttons -->
            <Button Style="{StaticResource ToolbarButtonStyle}" ToolTip="Fullscreen" FontSize="16" Margin="2">⛶</Button>
            <Button Style="{StaticResource ToolbarButtonStyle}" ToolTip="Playlist" FontSize="16" Margin="2">☰</Button>
            <Separator Background="{StaticResource ButtonHoverBg}" Width="1" Margin="6,0"/>
            
            <!-- Playback buttons -->
            <Button Style="{StaticResource ToolbarButtonStyle}" ToolTip="Loop/Repeat" FontSize="16" Margin="2">🔁</Button>
            <Button Style="{StaticResource ToolbarButtonStyle}" ToolTip="Shuffle" FontSize="16" Margin="2">🔀</Button>
            <Separator Background="{StaticResource ButtonHoverBg}" Width="1" Margin="6,0"/>
            
            <!-- Additional buttons -->
            <Button Style="{StaticResource ToolbarButtonStyle}" ToolTip="Effects and Filters" FontSize="16" Margin="2">✨</Button>
            <Button Style="{StaticResource SmallToolbarButtonStyle}" ToolTip="Audio Tools" Name="AudioToolsButton" Margin="2">Audio Tools</Button>
            <Button Style="{StaticResource ToolbarButtonStyle}" ToolTip="Preferences" FontSize="16" Margin="2">⚙️</Button>
            
            <TextBlock Name="CurrentTrackLabel" Foreground="{StaticResource TextDimFg}" VerticalAlignment="Center" Margin="20,0,0,0" FontSize="11" Text="No track loaded"/>
        </StackPanel>

        <!-- Main Content - Can be Video or Audio Tools Panel -->
        <Grid Grid.Row="2" Background="#000000">
            <!-- Video/Audio Viewer (Hidden when Audio Tools shown) -->
            <Rectangle Name="VideoBackground" Fill="#000000"/>
            <StackPanel Name="MediaViewerPlaceholder" VerticalAlignment="Center" HorizontalAlignment="Center">
                <TextBlock Text="♫" FontSize="80" Foreground="{StaticResource OrangeBrush}" TextAlignment="Center" Opacity="0.3"/>
                <TextBlock Text="No media loaded" Foreground="{StaticResource TextDimFg}" TextAlignment="Center" FontSize="14" Margin="0,8,0,0"/>
            </StackPanel>

            <!-- Audio Tools Panel (Hidden by default) -->
            <Border Name="AudioToolsPanel" Background="{StaticResource DarkBg}" Visibility="Collapsed">
                <TabControl Style="{StaticResource AudioToolsTabControlStyle}" Background="{StaticResource DarkBg}">
                    <!-- Persona Management Tab -->
                    <!-- Lexicon Tab -->
                    <TabItem Header="Lexicon" Style="{StaticResource AudioToolsTabItemStyle}">
                        <Grid Background="{StaticResource DarkBg}">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="*"/>
                            </Grid.RowDefinitions>

                            <ScrollViewer Grid.Row="0" VerticalScrollBarVisibility="Auto">
                                <StackPanel Margin="16">
                                    <TextBlock Text="Artist Lexicon" Foreground="{StaticResource OrangeBrush}" FontSize="16" FontWeight="Bold" Margin="0,0,0,12"/>
                                    <TextBlock Foreground="{StaticResource TextDimFg}" FontSize="12" Margin="0,0,0,12" TextWrapping="Wrap" Text="Unique tokens (words) from all songs. Green = trained, Red = needs training."/>

                                    <!-- Artist Selection -->
                                    <TextBlock Style="{StaticResource LabelStyle}" Text="Select Artist" FontWeight="Bold"/>
                                    <ComboBox x:Name="ArtistLexiconDropdown" Background="{StaticResource ControlBg}" Foreground="{StaticResource TextFg}" Padding="8" Height="32" Margin="0,0,0,16"/>

                                    <!-- Coverage Stats -->
                                    <Border Background="{StaticResource ControlBg}" BorderBrush="{StaticResource ButtonHoverBg}" BorderThickness="1" Padding="12" CornerRadius="4" Margin="0,0,0,16">
                                        <StackPanel>
                                            <StackPanel Orientation="Horizontal" Margin="0,0,0,8">
                                                <TextBlock Text="Total Tokens:" Foreground="{StaticResource TextFg}" FontWeight="Bold" Width="100"/>
                                                <TextBlock x:Name="LexiconTotalTokens" Text="0" Foreground="{StaticResource TextFg}"/>
                                            </StackPanel>
                                            <StackPanel Orientation="Horizontal" Margin="0,0,0,8">
                                                <TextBlock Text="Trained:" Foreground="#00FF00" FontWeight="Bold" Width="100"/>
                                                <TextBlock x:Name="LexiconTrainedCount" Text="0" Foreground="#00FF00"/>
                                            </StackPanel>
                                            <StackPanel Orientation="Horizontal" Margin="0,0,0,8">
                                                <TextBlock Text="Untrained:" Foreground="#FF0000" FontWeight="Bold" Width="100"/>
                                                <TextBlock x:Name="LexiconUntrainedCount" Text="0" Foreground="#FF0000"/>
                                            </StackPanel>
                                            <StackPanel Orientation="Horizontal">
                                                <TextBlock Text="Coverage:" Foreground="{StaticResource TextFg}" FontWeight="Bold" Width="100"/>
                                                <TextBlock x:Name="LexiconCoveragePercent" Text="0%" Foreground="{StaticResource OrangeBrush}"/>
                                            </StackPanel>
                                        </StackPanel>
                                    </Border>
                                </StackPanel>
                            </ScrollViewer>

                            <!-- Token Lists -->
                            <Grid Grid.Row="1" Margin="16">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>

                                <!-- Trained Tokens (Green) -->
                                <StackPanel Grid.Column="0" Margin="0,0,8,0">
                                    <TextBlock Text="✓ Trained Tokens" Foreground="#00FF00" FontWeight="Bold" Margin="0,0,0,8"/>
                                    <TextBox x:Name="TrainedTokensBox" Background="#1A3A1A" Foreground="#00FF00" Padding="8" VerticalScrollBarVisibility="Auto" TextWrapping="Wrap" IsReadOnly="True"/>
                                </StackPanel>

                                <!-- Untrained Tokens (Red) -->
                                <StackPanel Grid.Column="1" Margin="8,0,0,0">
                                    <TextBlock Text="✗ Untrained Tokens" Foreground="#FF0000" FontWeight="Bold" Margin="0,0,0,8"/>
                                    <TextBox x:Name="UntrainedTokensBox" Background="#3A1A1A" Foreground="#FF0000" Padding="8" VerticalScrollBarVisibility="Auto" TextWrapping="Wrap" IsReadOnly="True"/>
                                </StackPanel>
                            </Grid>
                        </Grid>
                    </TabItem>

                    <!-- Demucs Tools Tab -->
                    <TabItem Header="Demucs Tools" Style="{StaticResource AudioToolsTabItemStyle}">
                        <Grid Background="{StaticResource DarkBg}">
                            <ScrollViewer VerticalScrollBarVisibility="Auto">
                                <StackPanel Margin="16">
                                    <TextBlock Text="Demucs - Audio Source Separation" Foreground="{StaticResource OrangeBrush}" FontSize="16" FontWeight="Bold" Margin="0,0,0,12"/>
                                    
                                    <TextBlock Style="{StaticResource LabelStyle}" Text="Separation Model"/>
                                    <ComboBox Background="{StaticResource ControlBg}" Foreground="{StaticResource TextFg}" Padding="8" Height="32" Margin="0,0,0,12">
                                        <ComboBoxItem Foreground="{StaticResource TextFg}">HTDemucs (Default)</ComboBoxItem>
                                        <ComboBoxItem Foreground="{StaticResource TextFg}">HTDemucs 6s</ComboBoxItem>
                                        <ComboBoxItem Foreground="{StaticResource TextFg}">Demucs v3</ComboBoxItem>
                                        <ComboBoxItem Foreground="{StaticResource TextFg}">Demucs v2</ComboBoxItem>
                                    </ComboBox>

                                    <TextBlock Style="{StaticResource LabelStyle}" Text="Select Stems to Extract"/>
                                    <Grid Margin="0,0,0,12">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="*"/>
                                        </Grid.ColumnDefinitions>
                                        <StackPanel Margin="0,0,8,0">
                                            <CheckBox Foreground="{StaticResource TextFg}" Margin="0,0,0,8">✓ Vocals</CheckBox>
                                            <CheckBox Foreground="{StaticResource TextFg}">✓ Drums</CheckBox>
                                        </StackPanel>
                                        <StackPanel Grid.Column="1">
                                            <CheckBox Foreground="{StaticResource TextFg}" Margin="0,0,0,8">✓ Bass</CheckBox>
                                            <CheckBox Foreground="{StaticResource TextFg}">✓ Other</CheckBox>
                                        </StackPanel>
                                    </Grid>

                                    <TextBlock Style="{StaticResource LabelStyle}" Text="Processing Options"/>
                                    <StackPanel Margin="0,0,0,12">
                                        <Grid Margin="0,0,0,8">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="Auto"/>
                                            </Grid.ColumnDefinitions>
                                            <TextBlock Grid.Column="0" Text="GPU Acceleration" Foreground="{StaticResource TextFg}" VerticalAlignment="Center"/>
                                            <CheckBox Grid.Column="1" IsChecked="True" VerticalAlignment="Center"/>
                                        </Grid>
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="Auto"/>
                                            </Grid.ColumnDefinitions>
                                            <TextBlock Grid.Column="0" Text="Export as WAV" Foreground="{StaticResource TextFg}" VerticalAlignment="Center"/>
                                            <CheckBox Grid.Column="1" IsChecked="True" VerticalAlignment="Center"/>
                                        </Grid>
                                    </StackPanel>

                                    <Separator Background="{StaticResource ControlBg}" Margin="0,12"/>

                                    <Grid Margin="0,0,0,12">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="*"/>
                                        </Grid.ColumnDefinitions>
                                        <Button Grid.Column="0" Style="{StaticResource AudioToolsButtonStyle}" Margin="0,0,8,0">Split Audio</Button>
                                        <Button Grid.Column="1" Style="{StaticResource SecondaryButtonStyle}">Browse Stems</Button>
                                    </Grid>

                                    <TextBlock Style="{StaticResource LabelStyle}" Text="Processing Status" Margin="0,8,0,4" FontSize="11"/>
                                    <TextBlock Foreground="{StaticResource TextDimFg}" FontSize="11" Text="Ready to process"/>
                                </StackPanel>
                            </ScrollViewer>
                        </Grid>
                    </TabItem>

                    <!-- Piper TTS Tab -->
                    <TabItem Header="Piper TTS" Style="{StaticResource AudioToolsTabItemStyle}">
                        <Grid Background="{StaticResource DarkBg}">
                            <ScrollViewer VerticalScrollBarVisibility="Auto">
                                <StackPanel Margin="16">
                                    <TextBlock Text="Piper Text-to-Speech" Foreground="{StaticResource OrangeBrush}" FontSize="16" FontWeight="Bold" Margin="0,0,0,12"/>
                                    
                                    <TextBlock Style="{StaticResource LabelStyle}" Text="Load ONNX Model"/>
                                    <Grid Margin="0,0,0,12">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>
                                        <TextBox Grid.Column="0" Background="{StaticResource ControlBg}" Foreground="{StaticResource TextFg}" Padding="8" Height="32" Text="model.onnx"/>
                                        <Button Grid.Column="1" Style="{StaticResource SecondaryButtonStyle}" Margin="8,0,0,0" Padding="12,8">Browse</Button>
                                    </Grid>

                                    <TextBlock Style="{StaticResource LabelStyle}" Text="Load Config (ONNX.json)"/>
                                    <Grid Margin="0,0,0,12">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>
                                        <TextBox Grid.Column="0" Background="{StaticResource ControlBg}" Foreground="{StaticResource TextFg}" Padding="8" Height="32" Text="config.onnx.json"/>
                                        <Button Grid.Column="1" Style="{StaticResource SecondaryButtonStyle}" Margin="8,0,0,0" Padding="12,8">Browse</Button>
                                    </Grid>

                                    <Separator Background="{StaticResource ControlBg}" Margin="0,12"/>

                                    <TextBlock Style="{StaticResource LabelStyle}" Text="Text to Synthesize" FontWeight="Bold"/>
                                    <TextBox Background="{StaticResource ControlBg}" Foreground="{StaticResource TextFg}" Padding="8" Height="100" VerticalAlignment="Stretch" TextWrapping="Wrap" AcceptsReturn="True" Text="Enter text to convert to speech..." Margin="0,0,0,12"/>

                                    <TextBlock Style="{StaticResource LabelStyle}" Text="Voice Parameters" FontWeight="Bold" Margin="0,8,0,8"/>
                                    
                                    <Grid Margin="0,0,0,12">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="*"/>
                                        </Grid.ColumnDefinitions>
                                        <StackPanel Margin="0,0,8,0">
                                            <TextBlock Style="{StaticResource LabelStyle}" Text="Speaking Rate"/>
                                            <Slider Minimum="0.5" Maximum="2.0" Value="1.0" Background="{StaticResource ControlBg}" Foreground="{StaticResource OrangeBrush}" Margin="0,0,0,4"/>
                                            <TextBlock Foreground="{StaticResource TextDimFg}" FontSize="10" Text="1.0x"/>
                                        </StackPanel>
                                        <StackPanel Grid.Column="1">
                                            <TextBlock Style="{StaticResource LabelStyle}" Text="Pitch"/>
                                            <Slider Minimum="0.5" Maximum="2.0" Value="1.0" Background="{StaticResource ControlBg}" Foreground="{StaticResource OrangeBrush}" Margin="0,0,0,4"/>
                                            <TextBlock Foreground="{StaticResource TextDimFg}" FontSize="10" Text="1.0"/>
                                        </StackPanel>
                                    </Grid>

                                    <Separator Background="{StaticResource ControlBg}" Margin="0,12"/>

                                    <TextBlock Style="{StaticResource LabelStyle}" Text="Training" FontWeight="Bold" Margin="0,8,0,8"/>
                                    <TextBlock Style="{StaticResource LabelStyle}" Text="Add Training Sample" FontSize="12"/>
                                    <Grid Margin="0,0,0,12">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="*"/>
                                        </Grid.ColumnDefinitions>
                                        <StackPanel Margin="0,0,8,0">
                                            <TextBlock Style="{StaticResource LabelStyle}" Text="Audio File" FontSize="11"/>
                                            <Grid>
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="*"/>
                                                    <ColumnDefinition Width="Auto"/>
                                                </Grid.ColumnDefinitions>
                                                <TextBox Grid.Column="0" Background="{StaticResource ControlBg}" Foreground="{StaticResource TextFg}" Padding="8" Height="28" Text="audio.wav"/>
                                                <Button Grid.Column="1" Style="{StaticResource SecondaryButtonStyle}" Margin="4,0,0,0" Padding="8">...</Button>
                                            </Grid>
                                        </StackPanel>
                                        <StackPanel Grid.Column="1">
                                            <TextBlock Style="{StaticResource LabelStyle}" Text="Lyrics/Transcript" FontSize="11"/>
                                            <TextBox Background="{StaticResource ControlBg}" Foreground="{StaticResource TextFg}" Padding="8" Height="28" Text="Enter corresponding text"/>
                                        </StackPanel>
                                    </Grid>

                                    <Grid Margin="0,0,0,12">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="*"/>
                                        </Grid.ColumnDefinitions>
                                        <Button Grid.Column="0" Style="{StaticResource SecondaryButtonStyle}" Margin="0,0,4,0">Add Sample</Button>
                                        <Button Grid.Column="1" Style="{StaticResource SecondaryButtonStyle}" Margin="2,0">View Samples</Button>
                                        <Button Grid.Column="2" Style="{StaticResource AudioToolsButtonStyle}" Margin="4,0,0,0">Train</Button>
                                    </Grid>

                                    <Separator Background="{StaticResource ControlBg}" Margin="0,12"/>
                                    
                                    <Button Style="{StaticResource AudioToolsButtonStyle}" Padding="12,10">Generate Speech</Button>
                                </StackPanel>
                            </ScrollViewer>
                        </Grid>
                    </TabItem>

                    <!-- Voice Training Tab -->
                    <TabItem Header="Voice Training" Style="{StaticResource AudioToolsTabItemStyle}">
                        <Grid Background="{StaticResource DarkBg}">
                            <ScrollViewer VerticalScrollBarVisibility="Auto">
                                <StackPanel Margin="16">
                                    <TextBlock Text="Train Artist Voice Model" Foreground="{StaticResource OrangeBrush}" FontSize="16" FontWeight="Bold" Margin="0,0,0,12"/>
                                    <TextBlock Foreground="{StaticResource TextDimFg}" FontSize="12" Margin="0,0,0,12" TextWrapping="Wrap" Text="Use Whisper-transcribed audio samples to train a custom voice model. Minimum 5-10 samples recommended."/>

                                    <!-- Project Settings -->
                                    <TextBlock Style="{StaticResource LabelStyle}" Text="Project Name" FontWeight="Bold"/>
                                    <TextBox x:Name="ProjectNameBox" Background="{StaticResource ControlBg}" Foreground="{StaticResource TextFg}" Padding="8" Height="32" Text="My Artist Voice v1" Margin="0,0,0,12"/>

                                    <!-- Training Audio Folder -->
                                    <TextBlock Style="{StaticResource LabelStyle}" Text="Training Audio Folder" FontWeight="Bold"/>
                                    <Grid Margin="0,0,0,12">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>
                                        <TextBox Grid.Column="0" x:Name="TrainingAudioFolderBox" Background="{StaticResource ControlBg}" Foreground="{StaticResource TextFg}" Padding="8" Height="32" IsReadOnly="True" Text="(select folder)" Margin="0,0,8,0"/>
                                        <Button Grid.Column="1" x:Name="BrowseTrainingFolderButton" Style="{StaticResource SecondaryButtonStyle}" Padding="12,8">📁 Browse</Button>
                                    </Grid>

                                    <!-- Training Audio Files Selection -->
                                    <TextBlock Style="{StaticResource LabelStyle}" Text="Training Audio Files" FontWeight="Bold"/>
                                    <TextBlock Foreground="{StaticResource TextDimFg}" FontSize="11" Margin="0,0,0,8">Check files to include in training:</TextBlock>
                                    <Border Background="{StaticResource ControlBg}" BorderBrush="{StaticResource ButtonHoverBg}" BorderThickness="1" Padding="8" Height="140" CornerRadius="4" Margin="0,0,0,12">
                                        <ScrollViewer VerticalScrollBarVisibility="Auto">
                                            <StackPanel x:Name="TrainingFilesPanel"/>
                                        </ScrollViewer>
                                    </Border>

                                    <!-- Sample Length for Splitting -->
                                    <Grid Margin="0,0,0,12">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="*"/>
                                        </Grid.ColumnDefinitions>

                                        <StackPanel Margin="0,0,8,0">
                                            <TextBlock Style="{StaticResource LabelStyle}" Text="Sample Length (seconds)"/>
                                            <TextBlock Foreground="{StaticResource TextDimFg}" FontSize="10" Margin="0,0,0,4" Text="For splitting audio files"/>
                                            <TextBox x:Name="SampleLengthBox" Background="{StaticResource ControlBg}" Foreground="{StaticResource TextFg}" Padding="8" Height="32" Text="10"/>
                                        </StackPanel>

                                        <StackPanel Grid.Column="1">
                                            <TextBlock Style="{StaticResource LabelStyle}" Text="Whisper Model"/>
                                            <TextBlock Foreground="{StaticResource TextDimFg}" FontSize="10" Margin="0,0,0,4" Text="Click browse to select"/>
                                            <Grid>
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="*"/>
                                                    <ColumnDefinition Width="Auto"/>
                                                </Grid.ColumnDefinitions>
                                                <ComboBox Grid.Column="0" x:Name="WhisperModelDropdown" Background="{StaticResource ControlBg}" Foreground="{StaticResource TextFg}" Padding="8" Height="32" Margin="0,0,4,0"/>
                                                <Button Grid.Column="1" x:Name="BrowseWhisperModelButton" Style="{StaticResource SecondaryButtonStyle}" Padding="12,8">Browse</Button>
                                            </Grid>
                                        </StackPanel>
                                    </Grid>

                                    <!-- Training Parameters -->
                                    <TextBlock Style="{StaticResource LabelStyle}" Text="Training Parameters" FontWeight="Bold" Margin="0,8,0,8"/>
                                    
                                    <Grid Margin="0,0,0,12">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="*"/>
                                        </Grid.ColumnDefinitions>
                                        
                                        <StackPanel Margin="0,0,8,0">
                                            <TextBlock Style="{StaticResource LabelStyle}" Text="Number of Epochs"/>
                                            <TextBox Background="{StaticResource ControlBg}" Foreground="{StaticResource TextFg}" Padding="8" Height="32" Text="100"/>
                                        </StackPanel>
                                        
                                        <StackPanel Grid.Column="1">
                                            <TextBlock Style="{StaticResource LabelStyle}" Text="Batch Size"/>
                                            <TextBox Background="{StaticResource ControlBg}" Foreground="{StaticResource TextFg}" Padding="8" Height="32" Text="4"/>
                                        </StackPanel>
                                    </Grid>

                                    <Grid Margin="0,0,0,12">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="*"/>
                                        </Grid.ColumnDefinitions>
                                        
                                        <StackPanel Margin="0,0,8,0">
                                            <TextBlock Style="{StaticResource LabelStyle}" Text="Learning Rate"/>
                                            <TextBox Background="{StaticResource ControlBg}" Foreground="{StaticResource TextFg}" Padding="8" Height="32" Text="0.0001"/>
                                        </StackPanel>
                                        
                                        <StackPanel Grid.Column="1">
                                            <TextBlock Style="{StaticResource LabelStyle}" Text="Validation Split"/>
                                            <TextBox Background="{StaticResource ControlBg}" Foreground="{StaticResource TextFg}" Padding="8" Height="32" Text="0.1"/>
                                        </StackPanel>
                                    </Grid>

                                    <Separator Background="{StaticResource ControlBg}" Margin="0,12"/>

                                    <!-- Training Status -->
                                    <TextBlock Style="{StaticResource LabelStyle}" Text="Training Status" FontWeight="Bold" Margin="0,8,0,8"/>
                                    <Border Background="{StaticResource ControlBg}" BorderBrush="{StaticResource ButtonHoverBg}" BorderThickness="1" Padding="12" CornerRadius="4" Margin="0,0,0,12">
                                        <StackPanel>
                                            <StackPanel Orientation="Horizontal" Margin="0,0,0,8">
                                                <TextBlock Text="Status:" Foreground="{StaticResource TextFg}" FontWeight="Bold" Width="80"/>
                                                <TextBlock x:Name="TrainingStatusLabel" Text="Ready" Foreground="{StaticResource OrangeBrush}"/>
                                            </StackPanel>
                                            
                                            <StackPanel Orientation="Horizontal" Margin="0,0,0,8">
                                                <TextBlock Text="Samples:" Foreground="{StaticResource TextFg}" FontWeight="Bold" Width="80"/>
                                                <TextBlock x:Name="SampleCountLabel" Text="0 found" Foreground="{StaticResource TextDimFg}"/>
                                            </StackPanel>
                                            
                                            <StackPanel Orientation="Horizontal">
                                                <TextBlock Text="Progress:" Foreground="{StaticResource TextFg}" FontWeight="Bold" Width="80"/>
                                                <TextBlock x:Name="ProgressLabel" Text="0%" Foreground="{StaticResource TextDimFg}"/>
                                            </StackPanel>
                                        </StackPanel>
                                    </Border>

                                    <!-- Progress Bar -->
                                    <Grid Height="6" Margin="0,0,0,12">
                                        <Rectangle Fill="#404040" RadiusX="3" RadiusY="3"/>
                                        <Rectangle x:Name="TrainingProgressBar" Fill="{StaticResource OrangeBrush}" Width="0" HorizontalAlignment="Left" RadiusX="3" RadiusY="3"/>
                                    </Grid>

                                    <!-- Training Output Log -->
                                    <TextBlock Style="{StaticResource LabelStyle}" Text="Training Log" FontWeight="Bold" Margin="0,8,0,4"/>
                                    <TextBox Background="{StaticResource ControlBg}" Foreground="{StaticResource TextDimFg}" Padding="8" Height="120" VerticalScrollBarVisibility="Auto" IsReadOnly="True" FontFamily="Courier New" FontSize="10" x:Name="TrainingLogBox" Text="Awaiting training to start...&#10;" Margin="0,0,0,12"/>

                                    <!-- Action Buttons -->
                                    <Grid Margin="0,0,0,0">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="*"/>
                                        </Grid.ColumnDefinitions>
                                        
                                        <Button Grid.Column="0" Style="{StaticResource AudioToolsButtonStyle}" x:Name="ValidateDataButton" Margin="0,0,4,0">✓ Validate Data</Button>
                                        <Button Grid.Column="1" Style="{StaticResource SecondaryButtonStyle}" x:Name="RefreshFilesButton" Margin="2,0">🔄 Refresh Files</Button>
                                        <Button Grid.Column="2" Style="{StaticResource AudioToolsButtonStyle}" x:Name="StartTrainingButton" Margin="4,0,0,0" IsEnabled="False">🚀 Start Training</Button>
                                    </Grid>
                                </StackPanel>
                            </ScrollViewer>
                        </Grid>
                    </TabItem>

                    <!-- Lyrics Tools Tab -->
                    <TabItem Header="Lyrics Tools" Style="{StaticResource AudioToolsTabItemStyle}">
                        <Grid Background="{StaticResource DarkBg}">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>

                            <!-- Left Panel: View/Edit Lyrics -->
                            <StackPanel Margin="16,16,8,16">
                                <TextBlock Text="Lyrics Editor" Foreground="{StaticResource OrangeBrush}" FontSize="14" FontWeight="Bold" Margin="0,0,0,12"/>
                                <TextBlock Style="{StaticResource LabelStyle}" Text="Current Track Lyrics" FontSize="12" FontWeight="Bold" Margin="0,4,0,8"/>
                                <TextBox Background="{StaticResource ControlBg}" Foreground="{StaticResource TextFg}" Padding="8" VerticalScrollBarVisibility="Auto" TextWrapping="Wrap" AcceptsReturn="True" Text="[Verse 1]&#10;Lyrics will appear here...&#10;&#10;[Chorus]&#10;Edit your lyrics directly..." Margin="0,0,0,12"/>
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>
                                    <Button Grid.Column="0" Style="{StaticResource AudioToolsButtonStyle}" Margin="0,0,4,0">Save Lyrics</Button>
                                    <Button Grid.Column="1" Style="{StaticResource SecondaryButtonStyle}" Margin="4,0,0,0">Clear</Button>
                                </Grid>
                            </StackPanel>

                            <!-- Right Panel: Generate Lyrics -->
                            <StackPanel Grid.Column="1" Margin="8,16,16,16">
                                <TextBlock Text="Generate Song Lyrics" Foreground="{StaticResource OrangeBrush}" FontSize="14" FontWeight="Bold" Margin="0,0,0,12"/>
                                
                                <TextBlock Style="{StaticResource LabelStyle}" Text="Select Persona Lexicon" FontWeight="Bold"/>
                                <ComboBox Background="{StaticResource ControlBg}" Foreground="{StaticResource TextFg}" Padding="8" Height="32" Margin="0,0,0,12">
                                    <ComboBoxItem Foreground="{StaticResource TextFg}">Default Lexicon</ComboBoxItem>
                                    <ComboBoxItem Foreground="{StaticResource TextFg}">Pop Music</ComboBoxItem>
                                    <ComboBoxItem Foreground="{StaticResource TextFg}">Hip-Hop</ComboBoxItem>
                                    <ComboBoxItem Foreground="{StaticResource TextFg}">Rock</ComboBoxItem>
                                    <ComboBoxItem Foreground="{StaticResource TextFg}">Custom</ComboBoxItem>
                                </ComboBox>

                                <TextBlock Style="{StaticResource LabelStyle}" Text="Song Topic/Theme" FontWeight="Bold"/>
                                <TextBox Background="{StaticResource ControlBg}" Foreground="{StaticResource TextFg}" Padding="8" Height="32" Text="e.g., Love, Dreams, Journey" Margin="0,0,0,12"/>

                                <TextBlock Style="{StaticResource LabelStyle}" Text="Mood/Style" FontWeight="Bold"/>
                                <Grid Margin="0,0,0,12">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>
                                    <ComboBox Grid.Column="0" Background="{StaticResource ControlBg}" Foreground="{StaticResource TextFg}" Padding="8" Height="32" Margin="0,0,8,0">
                                        <ComboBoxItem Foreground="{StaticResource TextFg}">Happy</ComboBoxItem>
                                        <ComboBoxItem Foreground="{StaticResource TextFg}">Sad</ComboBoxItem>
                                        <ComboBoxItem Foreground="{StaticResource TextFg}">Energetic</ComboBoxItem>
                                        <ComboBoxItem Foreground="{StaticResource TextFg}">Melancholic</ComboBoxItem>
                                    </ComboBox>
                                    <ComboBox Grid.Column="1" Background="{StaticResource ControlBg}" Foreground="{StaticResource TextFg}" Padding="8" Height="32">
                                        <ComboBoxItem Foreground="{StaticResource TextFg}">Formal</ComboBoxItem>
                                        <ComboBoxItem Foreground="{StaticResource TextFg}">Casual</ComboBoxItem>
                                        <ComboBoxItem Foreground="{StaticResource TextFg}">Poetic</ComboBoxItem>
                                    </ComboBox>
                                </Grid>

                                <TextBlock Style="{StaticResource LabelStyle}" Text="Song Structure" FontWeight="Bold"/>
                                <StackPanel Margin="0,0,0,12">
                                    <CheckBox Foreground="{StaticResource TextFg}" Margin="0,0,0,8">✓ Verse</CheckBox>
                                    <CheckBox Foreground="{StaticResource TextFg}" IsChecked="True" Margin="0,0,0,8">✓ Chorus</CheckBox>
                                    <CheckBox Foreground="{StaticResource TextFg}">Bridge</CheckBox>
                                </StackPanel>

                                <TextBlock Style="{StaticResource LabelStyle}" Text="Number of Lines per Section" FontWeight="Bold"/>
                                <Slider Minimum="4" Maximum="16" Value="8" Background="{StaticResource ControlBg}" Foreground="{StaticResource OrangeBrush}" Margin="0,4,0,4"/>
                                <TextBlock Foreground="{StaticResource TextDimFg}" FontSize="10" Text="8 lines" Margin="0,0,0,12"/>

                                <Separator Background="{StaticResource ControlBg}" Margin="0,0,0,12"/>
                                
                                <Button Style="{StaticResource AudioToolsButtonStyle}" Padding="12,10">Generate New Lyrics</Button>
                            </StackPanel>
                        </Grid>
                    </TabItem>
                </TabControl>
            </Border>
        </Grid>

        <!-- Progress Bar -->
        <StackPanel Grid.Row="3" Background="{StaticResource ControlBg}" Margin="8,4">
            <Grid Height="4" Margin="0,0,0,4">
                <Rectangle Fill="#404040" RadiusX="2" RadiusY="2"/>
                <Rectangle Name="ProgressBar" Fill="{StaticResource OrangeBrush}" Width="0" HorizontalAlignment="Left" RadiusX="2" RadiusY="2"/>
            </Grid>
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <TextBlock Grid.Column="0" Name="CurrentTimeLabel" Text="00:00" Foreground="{StaticResource TextFg}" FontSize="11"/>
                <TextBlock Grid.Column="2" Name="TotalTimeLabel" Text="00:00" Foreground="{StaticResource TextFg}" FontSize="11"/>
            </Grid>
        </StackPanel>

        <!-- Playback Controls -->
        <StackPanel Grid.Row="4" Background="#0F0F0F" Orientation="Horizontal" VerticalAlignment="Center" Height="64" Margin="12">
            <!-- Volume control on left -->
            <Button Style="{StaticResource ControlButtonStyle}" Width="32" Height="32" FontSize="14" Margin="4">🔊</Button>
            <Slider Name="VolumeSlider" Width="80" VerticalAlignment="Center" Background="Transparent" Foreground="{StaticResource OrangeBrush}" Minimum="0" Maximum="100" Value="70" Margin="4"/>
            
            <Separator Background="{StaticResource ButtonHoverBg}" Width="1" Margin="12,0"/>
            
            <!-- Main playback controls (centered) -->
            <StackPanel Orientation="Horizontal" VerticalAlignment="Center" HorizontalAlignment="Center">
                <Button Style="{StaticResource ControlButtonStyle}" Width="40" Height="40" FontSize="20" ToolTip="Previous" Name="PreviousButton" Margin="6,0">⏮️</Button>
                <Button Style="{StaticResource ControlButtonStyle}" Width="48" Height="48" FontSize="24" ToolTip="Play/Pause" Name="PlayPauseButton" Margin="6,0">▶️</Button>
                <Button Style="{StaticResource ControlButtonStyle}" Width="40" Height="40" FontSize="20" ToolTip="Next" Name="NextButton" Margin="6,0">⏭️</Button>
                <Button Style="{StaticResource ControlButtonStyle}" Width="40" Height="40" FontSize="18" ToolTip="Stop" Name="StopButton" Margin="6,0">⏹️</Button>
            </StackPanel>
            
            <!-- Speed and subtitle controls on right -->
            <Separator Background="{StaticResource ButtonHoverBg}" Width="1" Margin="12,0" HorizontalAlignment="Right" />
            <Button Style="{StaticResource ControlButtonStyle}" Width="32" Height="32" FontSize="14" ToolTip="Speed" Margin="4">⚡</Button>
            <Button Style="{StaticResource ControlButtonStyle}" Width="32" Height="32" FontSize="14" ToolTip="Subtitles" Margin="4">🔤</Button>
            <Button Style="{StaticResource ControlButtonStyle}" Width="32" Height="32" FontSize="14" ToolTip="Audio Track" Margin="4">🎵</Button>
        </StackPanel>
    </Grid>
</Window>
