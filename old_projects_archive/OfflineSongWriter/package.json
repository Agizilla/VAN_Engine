{
  "name": "house-codex",
  "version": "1.0.0",
  "description": "Sovereign Lyrical Engine - Chopper Rap Generator",
  "main": "main.js",
  "scripts": {
    "dev": "concurrently \"python backend_api.py\" \"vite\"",
    "build:electron": "electron-builder",
    "start": "electron ."
  },
  "build": {
    "appId": "com.housecodex.app",
    "productName": "House Codex",
    "directories": {
      "output": "dist"
    },
    "files": [
      "**/*"
    ],
    "win": {
      "target": "nsis",
      "icon": "icon.ico"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true
    }
  },
  "keywords": [
    "lyrical-engine",
    "rap",
    "chopper",
    "hip-hop"
  ],
  "author": "House Codex",
  "license": "MIT",
  "dependencies": {
    "axios": "^1.6.8",
    "electron-store": "^8.2.0"
  },
  "devDependencies": {
    "@vitejs/plugin-react": "^5.1.0",
    "autoprefixer": "^10.4.19",
    "concurrently": "^8.2.2",
    "electron": "^29.1.4",
    "electron-builder": "^24.13.3",
    "postcss": "^8.4.38",
    "tailwindcss": "^3.4.1",
    "vite": "^5.2.8"
  }
}
