{
  "manifest_version": 3,
  "name": "Screen OCR Extractor",
  "version": "1.0",
  "description": "Drag a rectangle to capture and OCR text from any screen area",
  "permissions": [
    "activeTab",
    "clipboardWrite",
    "storage",
    "scripting",
    "offscreen"
  ],
  "host_permissions": [
    "<all_urls>"
  ],
  "action": {
    "default_popup": "popup.html",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "background": {
    "service_worker": "background.js"
  },
  "web_accessible_resources": [
    {
      "resources": [
        "vendor/tesseract/*",
        "vendor/tesseract-core/*",
        "vendor/tessdata/*"
      ],
      "matches": ["<all_urls>"]
    }
  ],
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content.js"],
      "css": ["styles.css"],
      "run_at": "document_end"
    }
  ]
}
